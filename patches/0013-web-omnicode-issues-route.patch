+// ---------------------------------------------------------------------------
+// Main Page Component
+// ---------------------------------------------------------------------------
+
+/**
+ * OmniCode Issues Route Page
+ *
+ * - Auto-detects all T3 Code projects with git remotes
+ * - Fetches open issues for each detected repo
+ * - Clicking an issue creates a worktree + opens a chat thread
+ * - Shows a real-time loading state as issues are fetched
+ */
+function OmniCodeIssuesPage() {
+  const detectedRepos = useOmniCodeProjectDetector();
+  const statusMap = useOmniCodeIssueData(detectedRepos);
+  const openIssueWorktree = useOmniCodeWorktreeFlow();
+  const [worktreeInProgress, setWorktreeInProgress] = useState<number | null>(
+    null,
+  );
+  const toastTimeoutRef = useRef<ReturnType<typeof setTimeout> | null>(null);
+
+  // Show a toast-like notification when a worktree is created
+  const [toast, setToast] = useState<{
+    message: string;
+    type: "success" | "error";
+  } | null>(null);
+
+  useEffect(() => {
+    if (toast) {
+      if (toastTimeoutRef.current) clearTimeout(toastTimeoutRef.current);
+      toastTimeoutRef.current = setTimeout(() => setToast(null), 4000);
+      return () => {
+        if (toastTimeoutRef.current) clearTimeout(toastTimeoutRef.current);
+      };
+    }
+  }, [toast]);
+
+  const handleOpenWorktree = useCallback(
+    async (issue: OmniCodeIssue, repo: DetectedRepo) => {
+      if (worktreeInProgress !== null) return;
+      setWorktreeInProgress(issue.number);
+
+      try {
+        const result = await openIssueWorktree(repo, issue);
+
+        if (result) {
+          setToast({
+            message: `Created worktree for #${issue.number} on branch ${result.branch}`,
+            type: "success",
+          });
+        } else {
+          setToast({
+            message: `Failed to create worktree for #${issue.number}`,
+            type: "error",
+          });
+        }
+      } catch {
+        setToast({
+          message: `Error creating worktree for #${issue.number}`,
+          type: "error",
+        });
+      } finally {
+        setWorktreeInProgress(null);
+      }
+    },
+    [openIssueWorktree, worktreeInProgress],
+  );
+
+  const sortedRepoKeys = useMemo(() => {
+    return Array.from(statusMap.entries()).sort((a, b) => {
+      const aName = `${a[1].repo.owner}/${a[1].repo.repo}`;
+      const bName = `${b[1].repo.owner}/${b[1].repo.repo}`;
+      return aName.localeCompare(bName);
+    });
+  }, [statusMap]);
+
+  return (
+    <ScrollArea className="h-full">
+      <div className="flex flex-col gap-4 p-4 sm:p-6">
+        {/* Header */}
+        <div className="flex items-center justify-between">
+          <div>
+            <h2 className="text-base font-semibold text-foreground">
+              Project Issues
+            </h2>
+            <p className="mt-0.5 text-[13px] text-muted-foreground/70">
+              {detectedRepos.length > 0
+                ? `${detectedRepos.length} git project${detectedRepos.length > 1 ? "s" : ""} detected`
+                : "Open a project to get started"}
+            </p>
+          </div>
+        </div>
+
+        {/* Content */}
+        {detectedRepos.length === 0 ? (
+          <NoProjectsDetected />
+        ) : sortedRepoKeys.length === 0 ? (
+          <div className="flex flex-col gap-3">
+            {detectedRepos.map((repo) => (
+              <ProjectCardSkeleton key={`${repo.owner}/${repo.repo}`} />
+            ))}
+          </div>
+        ) : (
+          <div className="flex flex-col gap-3">
+            {sortedRepoKeys.map(([key, status]) => (
+              <RepoCard
+                key={key}
+                status={status}
+                onOpenWorktree={handleOpenWorktree}
+                worktreeInProgress={worktreeInProgress}
+              />
+            ))}
+          </div>
+        )}
+
+        {/* Bottom spacing */}
+        <div className="h-8" />
+      </div>
+
+      {/* Toast notification */}
+      {toast && (
+        <div
+          className={`fixed bottom-6 right-6 z-50 flex items-center gap-2 rounded-lg border px-4 py-3 text-sm shadow-lg transition-all ${
+            toast.type === "success"
+              ? "border-green-500/30 bg-green-500/10 text-green-500"
+              : "border-red-500/30 bg-red-500/10 text-red-500"
+          }`}
+          role="alert"
+        >
+          {toast.type === "success" ? (
+            <CheckCircle2Icon className="size-4 shrink-0" />
+          ) : (
+            <AlertCircleIcon className="size-4 shrink-0" />
+          )}
+          <span>{toast.message}</span>
+        </div>
+      )}
+    </ScrollArea>
+  );
+}
