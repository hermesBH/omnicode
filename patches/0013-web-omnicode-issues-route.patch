+function formatRelativeTime(dateStr: string): string {
+  const now = Date.now();
+  const then = new Date(dateStr).getTime();
+  const diffMs = now - then;
+  const diffMinutes = Math.floor(diffMs / 60000);
+  if (diffMinutes < 1) return "just now";
+  if (diffMinutes < 60) return `${diffMinutes}m ago`;
+  const diffHours = Math.floor(diffMinutes / 60);
+  if (diffHours < 24) return `${diffHours}h ago`;
+  const diffDays = Math.floor(diffHours / 24);
+  if (diffDays < 30) return `${diffDays}d ago`;
+  return new Date(dateStr).toLocaleDateString();
+}
+
+function repoLabelClass(label: string): string {
+  const lower = label.toLowerCase();
+  if (lower.includes("bug")) return "bg-red-500/10 text-red-500 border-red-500/30";
+  if (lower.includes("enhancement") || lower.includes("feature"))
+    return "bg-purple-500/10 text-purple-500 border-purple-500/30";
+  if (lower.includes("good first"))
+    return "bg-green-500/10 text-green-500 border-green-500/30";
+  if (lower.includes("help wanted"))
+    return "bg-amber-500/10 text-amber-500 border-amber-500/30";
+  if (lower.includes("documentation"))
+    return "bg-blue-500/10 text-blue-500 border-blue-500/30";
+  return "bg-muted/50 text-muted-foreground border-border/50";
+}
+
+function slugify(text: string, maxLen = 40): string {
+  return text
+    .toLowerCase()
+    .replace(/[^a-z0-9]+/g, "-")
+    .replace(/^-+|-+$/g, "")
+    .slice(0, maxLen)
+    .replace(/-+$/, "");
+}
