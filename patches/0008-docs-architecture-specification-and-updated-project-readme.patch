+### Usage Example
+
+```typescript
+import { GitHubClient, IssuesService, gitHubClientLayer, issuesServiceLayer } from "@omnicode/github";
+import { Effect } from "effect";
+
+const program = IssuesService.pipe(
+  Effect.flatMap((issues) =>
+    issues.getIssue("octocat", "Hello-World", 1)
+  ),
+  Effect.flatMap((issue) =>
+    Effect.logInfo(`Issue #${issue.number}: ${issue.title}`)
