+                        <p className="mt-0.5 text-[11px] text-muted-foreground/50">
+                          {formatRelativeTime(run.startedAt)}
+                        </p>
+                      </div>
+                    </div>
+                  ))}
+                </div>
+              </div>
+            </>
+          )}
+        </div>
+      </ScrollArea>
+    </div>
+  );
+}
