+// ==================== Service Shape ====================
+
+export interface ReposServiceShape {
+  readonly searchRepos: (input: RepoSearchInput) => Effect.Effect<RepoSearchResult, GitHubApiError | GitHubNotFoundError | GitHubRateLimitError>;
