+      setAgents((prev) =>
+        prev.map((a) => (a.id === agentId ? { ...a, status: "running" as const } : a)),
+      );
+
+      // Simulate agent run
+      setTimeout(() => {
+        const agent = agents.find((a) => a.id === agentId);
+        setAgents((prev) =>
+          prev.map((a) => (a.id === agentId ? { ...a, status: "success" as const } : a)),
+        );
+        setRecentRuns((prev) => [
+          {
+            id: `r-${Date.now()}`,
