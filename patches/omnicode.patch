+
+          {recentRuns.length > 0 && (
+            <>
+              <Separator className="my-2" />
+              <div>
+                <h3 className="mb-3 text-xs font-medium text-muted-foreground uppercase tracking-wider">
+                  Recent Runs
+                </h3>
+                <div className="flex flex-col gap-2" role="list" aria-label="Recent agent runs">
+                  {recentRuns.map((run) => (
+                    <div
