+// ==================== Domain Types ====================
+
+export interface GitHubRepo {
+  readonly id: number;
+  readonly name: string;
+  readonly fullName: string;
+  readonly description: string | null;
+  readonly htmlUrl: string;
+  readonly url: string;
+  readonly homepage: string | null;
