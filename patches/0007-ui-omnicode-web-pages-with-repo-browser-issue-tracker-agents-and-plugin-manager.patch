+              )}
+
+              {disabledCount > 0 && (
+                <>
+                  <h3 className="mt-2 text-xs font-medium text-muted-foreground uppercase tracking-wider">
+                    Disabled — {disabledCount}
+                  </h3>
+                  {plugins
+                    .filter((p) => !p.enabled)
+                    .map((plugin) => (
+                      <PluginCard
+                        key={plugin.id}
