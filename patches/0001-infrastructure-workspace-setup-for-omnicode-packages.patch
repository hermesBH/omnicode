From b3e8c033 Mon Sep 17 00:00:00 2006
From: *** Dev <dev@omnicode.dev>
Date: Tue, 2 Jun 2026 00:00:00 +0000
Subject: [PATCH 1/8] Infrastructure: Workspace setup for OmniCode packages

Add 4 new packages (omnicode-contracts, omnicode-plugin, omnicode-github, omnicode-ai) to workspace config, tsconfig, package.jsons, and app deps.
---

diff --git a/apps/server/package.json b/apps/server/package.json
index fac1b924..fb9b20f2 100644
--- a/apps/server/package.json
+++ b/apps/server/package.json
@@ -28,6 +28,10 @@
     "@effect/platform-node": "catalog:",
     "@effect/platform-node-shared": "catalog:",
     "@effect/sql-sqlite-bun": "catalog:",
+    "@omnicode/ai": "workspace:*",
+    "@omnicode/contracts": "workspace:*",
+    "@omnicode/github": "workspace:*",
+    "@omnicode/plugin": "workspace:*",
     "@opencode-ai/sdk": "^1.3.15",
     "@pierre/diffs": "catalog:",
     "effect": "catalog:",
diff --git a/packages/core/package.json b/packages/core/package.json
new file mode 100644
index 00000000..c781aa82
--- /dev/null
+++ b/packages/core/package.json
@@ -0,0 +1,32 @@
+{
+  "name": "@t3tools/core",
+  "version": "0.0.1",
+  "private": true,
+  "files": [
+    "src"
+  ],
+  "type": "module",
+  "exports": {
+    "./omnicode": {
+      "types": "./src/omnicode/omnicodeServer.ts",
+      "import": "./src/omnicode/omnicodeServer.ts"
+    },
+    "./omnicode-router": {
+      "types": "./src/omnicode/omnicodeRouter.ts",
+      "import": "./src/omnicode/omnicodeRouter.ts"
+    }
+  },
+  "scripts": {
+    "typecheck": "tsgo --noEmit"
+  },
+  "dependencies": {
+    "@omnicode/ai": "workspace:*",
+    "@omnicode/contracts": "workspace:*",
+    "@omnicode/github": "workspace:*",
+    "@omnicode/plugin": "workspace:*",
+    "effect": "catalog:"
+  },
+  "devDependencies": {
+    "typescript": "catalog:"
+  }
+}
diff --git a/packages/omnicode-ai/package.json b/packages/omnicode-ai/package.json
new file mode 100644
index 00000000..13f11aaa
--- /dev/null
+++ b/packages/omnicode-ai/package.json
@@ -0,0 +1,25 @@
+{
+  "name": "@omnicode/ai",
+  "version": "0.1.0",
+  "type": "module",
+  "main": "./src/index.ts",
+  "types": "./src/index.ts",
+  "exports": {
+    ".": "./src/index.ts",
+    "./agent": "./src/Agent.ts",
+    "./registry": "./src/AgentRegistry.ts",
+    "./types": "./src/types.ts",
+    "./review": "./src/review/CodeReviewAgent.ts",
+    "./triage": "./src/triage/IssueTriageAgent.ts"
+  },
+  "files": ["src"],
+  "scripts": {
+    "typecheck": "tsgo --noEmit"
+  },
+  "dependencies": {
+    "effect": "catalog:"
+  },
+  "peerDependencies": {
+    "typescript": "catalog:"
+  }
+}
diff --git a/packages/omnicode-ai/tsconfig.json b/packages/omnicode-ai/tsconfig.json
new file mode 100644
index 00000000..2341e9d4
--- /dev/null
+++ b/packages/omnicode-ai/tsconfig.json
@@ -0,0 +1,10 @@
+{
+  "extends": "../../tsconfig.base.json",
+  "compilerOptions": {
+    "outDir": "./dist",
+    "rootDir": "./src",
+    "tsBuildInfoFile": "./dist/tsconfig.tsbuildinfo"
+  },
+  "include": ["src"],
+  "references": []
+}
