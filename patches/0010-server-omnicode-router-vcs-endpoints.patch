+// =============================================================================
+// NEW: GET /api/omnicode/projects/detect-remote
+// =============================================================================
+
+/**
+ * Detect git remote info for a project directory.
+ *
+ * Query parameters:
+ *   - cwd (required): Absolute path to the project directory
+ *
+ * Response (200):
+ * ```json
+ * { "hasRemote": true, "remoteUrl": "git@github.com:owner/repo.git",
+ *   "owner": "owner", "repo": "repo", "provider": "github" }
+ * ```
+ *
+ * Returns `{ "hasRemote": false }` if no git remote is found.
+ *
+ * Requires VcsIntegrationService (from omnicodeGitIntegration).
+ */
+const detectRemoteHandler = Effect.gen(function* () {
+  const vcs: VcsIntegrationShape = yield* VcsIntegrationService;
+  const params = yield* getQueryParams;
+
+  const cwd = params["cwd"];
+  if (!cwd || cwd.trim().length === 0) {
+    return HttpServerResponse.text(
+      "Missing required query parameter: cwd",
+      { status: 400 },
+    );
+  }
+
+  const result = yield* vcs.detectRemote({ cwd });
+  return HttpServerResponse.jsonUnsafe(result, { status: 200 });
+}).pipe(
+  Effect.catchAll((error) =>
+    Effect.succeed(
+      HttpServerResponse.text(`Remote detection failed: ${error}`, { status: 500 }),
+    ),
+  ),
+);
+
+export const omnicodeDetectRemoteRouteLayer: Layer.Layer<
+  never,
+  never,
+  VcsIntegrationService
+> = HttpRouter.add(
+  "GET",
+  "/api/omnicode/projects/detect-remote",
+  detectRemoteHandler,
+);
+
+// =============================================================================
+// NEW: POST /api/omnicode/worktree
+// =============================================================================
+
+/**
+ * Create a git worktree for an issue.
+ *
+ * Creates a new feature branch based on the issue number and title,
+ * then creates a git worktree at `.worktrees/<branch-name>` relative
+ * to the repo root.
+ *
+ * Request body (JSON):
+ * ```json
+ * { "cwd": "/path/to/repo", "issueNumber": 42,
+ *   "issueTitle": "Fix login bug", "owner": "org", "repo": "repo-name" }
+ * ```
+ *
+ * Response (200):
+ * ```json
+ * { "branch": "feature/issues/42-fix-login-bug",
+ *   "worktreePath": "/path/to/repo/.worktrees/feature-issues-42-fix-login-bug",
+ *   "gitDir": ".git" }
+ * ```
+ *
+ * Error (500): If the path is not a git repo or worktree creation fails.
+ *
+ * Requires VcsIntegrationService (from omnicodeGitIntegration).
+ */
+const worktreeCreateHandler = Effect.gen(function* () {
+  const vcs: VcsIntegrationShape = yield* VcsIntegrationService;
+  const body = yield* getJsonBody;
+
+  // Validate request body against CreateIssueWorktreeInput schema
+  const validationResult = yield* Effect.either(
+    Schema.decodeUnknown(CreateIssueWorktreeInput)(body),
+  );
+
+  if (Either.isLeft(validationResult)) {
+    return HttpServerResponse.text(
+      `Invalid request body: ${validationResult.left.message}`,
+      { status: 400 },
+    );
+  }
+
+  const input: typeof CreateIssueWorktreeInput.Type = validationResult.right;
+
+  const result: CreateIssueWorktreeResult = yield* vcs.createIssueWorktree(input);
+
+  return HttpServerResponse.jsonUnsafe(result, { status: 200 });
+}).pipe(
+  Effect.catchAll((error) =>
+    Effect.succeed(
+      HttpServerResponse.text(`Worktree creation failed: ${error}`, { status: 500 }),
+    ),
+  ),
+);
+
+export const omnicodeWorktreeRouteLayer: Layer.Layer<
+  never,
+  never,
+  VcsIntegrationService
+> = HttpRouter.add(
+  "POST",
+  "/api/omnicode/worktree",
+  worktreeCreateHandler,
+);
